{
  "name": "nicflix",
  "version": "0.1.0",
  "description": "Local-first media server for browsing and streaming your own movie and TV library.",
  "private": true,
  "main": "electron/main.cjs",
  "workspaces": [
    "apps/client",
    "apps/server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w apps/server\" \"npm run dev -w apps/client\"",
    "dev:server": "npm run dev -w apps/server",
    "dev:client": "npm run dev -w apps/client",
    "build": "npm run build -w apps/client",
    "start": "npm run start -w apps/server",
    "desktop": "electron .",
    "icon:win": "powershell -ExecutionPolicy Bypass -File scripts/create-windows-icon.ps1",
    "sync:versions": "node scripts/sync-versions.cjs",
    "version": "node scripts/sync-versions.cjs --stage",
    "dist:win": "npm run icon:win && npm run build && electron-builder --win nsis"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "fluent-ffmpeg": "^2.1.3",
    "mime-types": "^2.1.35"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.nicflix.app",
    "productName": "NicFlix",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "apps/server/**/*",
      "!apps/server/.env",
      "apps/client/dist/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**/*"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NicFlix"
    }
  }
}
